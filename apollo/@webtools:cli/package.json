{
  "name": "@uu-webtools/cli",
  "version": "1.0.1",
  "description": "Webtools CLI",
  "type": "module",
  "bin": {
    "webtools": "./src/index.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:all": "rm -f tests/performance-data.jsonl && WEBTOOLS_TEST_TOKEN=test node ./node_modules/vitest/vitest.mjs run && node tests/format-report.js",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:backend": "node ./node_modules/vitest/vitest.mjs run tests/backend.test.js",
    "test:roundtrip": "node ./node_modules/vitest/vitest.mjs run tests/backend-roundtrip.test.js",
    "test:bulk": "node ./node_modules/vitest/vitest.mjs run tests/backend-bulk.test.js",
    "test:lists": "node ./node_modules/vitest/vitest.mjs run tests/backend-lists.test.js",
    "test:languages": "node ./node_modules/vitest/vitest.mjs run tests/backend-languages.test.js",
    "test:cli": "node ./node_modules/vitest/vitest.mjs run tests/cli.test.js",
    "test:speed": "node ./node_modules/vitest/vitest.mjs run tests/cli-speed.test.js"
  },
  "keywords": [
    "webtools",
    "i18n",
    "translations",
    "cli"
  ],
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
